{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "E:/Program Files/Dev-Cpp/MinGW64/bin/gcc.exe",
            "args": [
                "-g",
                "-o",
                "${workspaceFolder}/TravelNavigation.exe",
                "${workspaceFolder}/main.c",
                "${workspaceFolder}/graph.c",
                "${workspaceFolder}/menu.c",
                "${workspaceFolder}/travels.c",
                "${workspaceFolder}/global.c",
                "-std=c11",
                "-Wall"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$gcc",
            "detail": "编译景区路径规划系统"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "E:/Program Files/Dev-Cpp/MinGW64/bin/gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "调试器生成的任务。"
        }
    ]
}